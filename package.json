{
  "name": "money-tracker",
  "version": "0.1.0",
  "description": "Private, offline-first personal finance tool. Open source AGPL-3.0.",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && node scripts/spa-fallback.mjs",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "verify": "pnpm format:check && pnpm lint && pnpm check && pnpm test:cov && pnpm build",
    "validate:integration": "vitest run tests/unit/adapters tests/unit/regression",
    "validate:integration:real": "vitest run tests/unit/adapters",
    "trace": "node scripts/trace-requirements.mjs",
    "lint:lockfile": "node scripts/lint-lockfile.mjs",
    "audit:deps": "pnpm audit --audit-level=high",
    "scan:secrets": "echo 'gitleaks not installed locally; runs in CI. Install per docs/threat-model.md to scan pre-push.'",
    "security": "pnpm lint:lockfile && pnpm audit:deps",
    "validate:deep": "pnpm verify && pnpm test:e2e && pnpm validate:integration && pnpm mutate",
    "mutate": "stryker run",
    "gen:fixture": "tsx scripts/gen-fixture.ts",
    "anonymize": "tsx scripts/anonymize-statement.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "bits-ui": "^1.0.0",
    "chrono-node": "^2.9.1",
    "clsx": "^2.1.1",
    "echarts": "^6.1.0",
    "pdfjs-dist": "^4.4.168",
    "tailwind-merge": "^2.6.0",
    "tailwind-variants": "^0.3.0",
    "wa-sqlite": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.50.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-svelte": "^2.46.0",
    "fast-check": "^4.8.0",
    "globals": "^15.14.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^4.0.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
